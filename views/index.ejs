<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Nonton Anime</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-black text-gray-300 font-sans antialiased pb-10">
    
    <nav class="sticky top-0 z-50 bg-neutral-900 border-b border-blue-500 mb-6">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center justify-between h-14">
                <a href="/" class="flex items-center gap-3">
                    <div class="bg-blue-500 text-black flex items-center justify-center w-7 h-7 rounded-[5px]">
                        <i class="fa-solid fa-code text-xs"></i>
                    </div>
                    <span class="text-white font-bold text-base tracking-wide border-l border-neutral-700 pl-3">Nonton<span class="text-blue-500">Anime</span></span>
                </a>
                <a href="/bookmark" class="text-gray-300 hover:text-blue-500 transition">
                    <i class="fa-solid fa-bookmark text-lg"></i>
                </a>
            </div>
        </div>
    </nav>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="mb-8 max-w-2xl mx-auto">
            <form action="/search" method="GET" class="relative flex items-center">
                <input type="text" name="q" placeholder="Cari anime..." value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>" class="w-full bg-neutral-900 border border-neutral-800 text-white px-4 py-2.5 rounded-[5px] focus:outline-none focus:border-blue-500 text-sm transition">
                <button type="submit" class="absolute right-1.5 bg-blue-500 text-black px-4 py-1.5 rounded-[5px] text-sm font-bold hover:bg-blue-600 transition">Cari</button>
            </form>
        </div>

        <h1 class="text-lg font-bold mb-6 text-white border-l-4 border-blue-500 pl-3">
            <%= typeof searchQuery !== 'undefined' ? 'Pencarian: ' + searchQuery : 'Sedang Tayang' %>
        </h1>

        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3">
            <% if (animeList && animeList.length > 0) { %>
                <% animeList.forEach(anime => { %>
                    <a href="<%= anime.link %>" class="group block bg-neutral-900 rounded-[5px] overflow-hidden border border-neutral-800 hover:border-blue-500 transition">
                        <div class="relative aspect-[3/4] bg-neutral-800">
                            <img src="<%= anime.image %>" alt="<%= anime.title %>" class="absolute inset-0 w-full h-full object-cover">
                            <div class="absolute top-2 right-2 bg-black/80 text-blue-400 text-[10px] font-bold px-1.5 py-0.5 rounded-[5px]"><%= anime.episode %></div>
                        </div>
                        <div class="p-2.5">
                            <h2 class="text-sm font-semibold text-white line-clamp-2 leading-tight mb-1 group-hover:text-blue-500 transition"><%= anime.title %></h2>
                            <div class="text-[11px] text-gray-500"><%= anime.day %></div>
                        </div>
                    </a>
                <% }) %>
            <% } else { %>
                <div class="col-span-full py-10 text-center text-gray-500 text-sm">Tidak ada anime yang ditemukan.</div>
            <% } %>
        </div>

        <% if (typeof searchQuery === 'undefined') { %>
            <div class="flex justify-center items-center mt-8 space-x-2">
                <% if (currentPage > 1) { %>
                    <a href="/page/<%= currentPage - 1 %>" class="px-4 py-2 bg-neutral-900 border border-neutral-800 rounded-[5px] text-sm font-medium text-gray-300 hover:text-blue-500 hover:border-blue-500 transition">Kembali</a>
                <% } %>
                <span class="text-sm font-bold text-blue-500 bg-blue-500/10 border border-blue-500/20 px-4 py-2 rounded-[5px]">Hal <%= currentPage %></span>
                <a href="/page/<%= currentPage + 1 %>" class="px-4 py-2 bg-blue-500 text-black rounded-[5px] text-sm font-bold hover:bg-blue-600 transition">Lanjut</a>
            </div>
        <% } %>
    </div>
</body>
</html>
