<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-black text-gray-300 font-sans antialiased pb-10">

    <nav class="sticky top-0 z-50 bg-neutral-900 border-b border-blue-500 mb-6">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center justify-between h-14">
                <a href="/" class="flex items-center gap-3">
                    <div class="bg-blue-500 text-black flex items-center justify-center w-7 h-7 rounded-[5px]">
                        <i class="fa-solid fa-code text-xs"></i>
                    </div>
                    <span class="text-white font-bold text-base tracking-wide border-l border-neutral-700 pl-3">Nonton<span class="text-blue-500">Anime</span></span>
                </a>
                <a href="/bookmark" class="text-gray-300 hover:text-blue-500 transition">
                    <i class="fa-solid fa-bookmark text-lg"></i>
                </a>
            </div>
        </div>
    </nav>

    <div class="max-w-4xl mx-auto px-4 sm:px-6">
        <a href="javascript:history.back()" class="inline-flex items-center text-sm font-medium text-blue-500 hover:text-blue-400 mb-5 transition">
            &larr; Kembali
        </a>

        <div class="bg-neutral-900 p-4 sm:p-6 rounded-[5px] border border-neutral-800 mb-6 relative">
            <button id="bookmarkBtn" onclick="toggleBookmark()" class="absolute top-4 right-4 bg-neutral-800 hover:bg-blue-500 text-white w-10 h-10 rounded-[5px] flex items-center justify-center transition border border-neutral-700 hover:border-blue-500">
                <i id="bookmarkIcon" class="fa-regular fa-bookmark"></i>
            </button>
            <div class="flex flex-col sm:flex-row gap-5 mt-8 sm:mt-0">
                <div class="flex-shrink-0 w-32 sm:w-40 mx-auto sm:mx-0">
                    <img id="animeImage" src="<%= image %>" alt="<%= title %>" class="w-full rounded-[5px] aspect-[3/4] object-cover border border-neutral-800">
                </div>
                <div>
                    <h1 id="animeTitle" class="text-xl sm:text-2xl font-bold text-white mb-2 leading-tight text-center sm:text-left pr-0 sm:pr-12"><%= title %></h1>
                    <p class="text-sm text-gray-400 leading-relaxed text-justify sm:text-left"><%= synopsis %></p>
                </div>
            </div>
        </div>
        
        <h2 class="text-lg font-bold mb-3 px-1 text-white border-l-4 border-blue-500 pl-3">Daftar Episode</h2>
        <div class="bg-neutral-900 rounded-[5px] border border-neutral-800 overflow-hidden">
            <ul class="divide-y divide-neutral-800">
                <% episodeList.forEach(ep => { %>
                    <li>
                        <a href="<%= ep.epLink %>" data-link="<%= ep.epLink %>" class="episode-link flex justify-between items-center p-3.5 hover:bg-neutral-800 transition group">
                            <span class="ep-title text-sm font-medium text-gray-300 truncate pr-4 group-hover:text-blue-500 transition"><i class="fa-solid fa-play text-[10px] mr-2 text-neutral-600 ep-icon"></i><%= ep.epTitle %></span>
                            <span class="text-[11px] text-gray-500 whitespace-nowrap"><%= ep.epDate %></span>
                        </a>
                    </li>
                <% }) %>
            </ul>
        </div>
    </div>

    <script>
        const animeData = {
            title: document.getElementById('animeTitle').innerText,
            image: document.getElementById('animeImage').src,
            link: window.location.pathname
        };
        const bookmarkIcon = document.getElementById('bookmarkIcon');
        const bookmarkBtn = document.getElementById('bookmarkBtn');

        // Logika Bookmark
        function checkBookmark() {
            let bookmarks = JSON.parse(localStorage.getItem('animeBookmarks')) || [];
            const isBookmarked = bookmarks.some(b => b.link === animeData.link);
            if (isBookmarked) {
                bookmarkIcon.classList.remove('fa-regular');
                bookmarkIcon.classList.add('fa-solid', 'text-blue-500');
            } else {
                bookmarkIcon.classList.add('fa-regular');
                bookmarkIcon.classList.remove('fa-solid', 'text-blue-500');
            }
        }

        function toggleBookmark() {
            let bookmarks = JSON.parse(localStorage.getItem('animeBookmarks')) || [];
            const index = bookmarks.findIndex(b => b.link === animeData.link);
            
            if (index === -1) {
                bookmarks.push(animeData);
            } else {
                bookmarks.splice(index, 1);
            }
            
            localStorage.setItem('animeBookmarks', JSON.stringify(bookmarks));
            checkBookmark();
        }

        // Logika Episode Ditonton
        function checkWatchedEpisodes() {
            const watched = JSON.parse(localStorage.getItem('watchedEpisodes')) || [];
            document.querySelectorAll('.episode-link').forEach(el => {
                const link = el.getAttribute('data-link');
                if (watched.includes(link)) {
                    el.classList.add('bg-neutral-950');
                    const titleSpan = el.querySelector('.ep-title');
                    titleSpan.classList.replace('text-gray-300', 'text-gray-500');
                    const icon = el.querySelector('.ep-icon');
                    icon.classList.replace('fa-play', 'fa-check');
                    icon.classList.replace('text-neutral-600', 'text-blue-500');
                }
            });
        }

        checkBookmark();
        checkWatchedEpisodes();
    </script>
</body>
</html>
